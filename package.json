{
  "name": "clean-slop",
  "version": "2.0.0",
  "description": "A production readiness engine for modern JavaScript and TypeScript projects. Prevents low-quality, insecure, and AI-generated code from reaching production.",
  "keywords": [
    "linter",
    "security",
    "code-quality",
    "static-analysis",
    "ai",
    "production-readiness",
    "typescript",
    "javascript",
    "cli",
    "devtools"
  ],
  "homepage": "https://clean-slop.vercel.app",
  "bugs": {
    "url": "https://github.com/aaks-hath/clean-slop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aaks-hath/clean-slop.git"
  },
  "license": "MIT",
  "author": "clean-slop contributors",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clean-slop": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rimraf dist",
    "dev": "tsx src/cli/bin.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "prebuild": "npm run clean",
    "prepare": "npm run build",
    "release": "npm run build && npm publish --access public",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@typescript-eslint/typescript-estree": "^6.13.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "cosmiconfig": "^9.0.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.0",
    "is-binary-path": "^2.1.0",
    "js-yaml": "^4.1.0",
    "ora": "^7.0.1",
    "semver": "^7.5.4",
    "strip-ansi": "^7.1.0",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/semver": "^7.5.6",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
